{
  "name": "syntony-grpc",
  "version": "0.1.0",
  "description": "Real gRPC transport for Syntony — turns the embedded CRDT primitive into a live, decentralized cluster of peer nodes with SWIM membership, gossip, and anti-entropy over the network.",
  "license": "Apache-2.0",
  "author": "Jorge Jimenez <npm@jorgejim.com>",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "proto"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "demo": "npm run build && node examples/cluster-demo.mjs",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "syntony",
    "grpc",
    "crdt",
    "swim",
    "gossip",
    "distributed",
    "decentralized"
  ],
  "dependencies": {
    "@grpc/grpc-js": "^1.12.5",
    "@grpc/proto-loader": "^0.7.13",
    "syntony": "^0.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.19.21",
    "syntony-flag": "^0.1.0",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
